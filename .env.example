# Experiment Hub — environment variables
# Copy to .env.local for local dev (Next.js loads .env.local automatically).
# For Vercel: set these in Project Settings → Environment Variables.

# Notion API key — required on Vercel (and any non-Replit host).
# Create an integration at https://www.notion.so/my-integrations, share your
# landing submissions database with it, then paste the secret here.
# On Replit this is handled automatically via the Notion connector.
NOTION_TOKEN=

# Landing form submissions: one Notion database per experiment (recommended).
# Env key = NOTION_LANDING_DATABASE_ID_<EXPERIMENT_SLUG> (slug = name in UPPER_SNAKE_CASE).
# Example: "Best Day Ever" → NOTION_LANDING_DATABASE_ID_BEST_DAY_EVER
NOTION_LANDING_DATABASE_ID_BEST_DAY_EVER=

# Optional fallback: used when no per-experiment var is set (e.g. NOTION_LANDING_DATABASE_ID_BEST_DAY_EVER).
# NOTION_LANDING_DATABASE_ID=

# Optional: restrict CORS for /api/landing-submission (default: *)
# LANDING_CORS_ORIGIN=https://your-landing-domain.com
