# Experiment Hub — environment variables
# Copy to .env.local for local dev (Next.js loads .env.local automatically).
# For Vercel: set these in Project Settings → Environment Variables.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Used for all experiment waitlist/form submissions.
# Find these in your Supabase project: Settings → API (or the Connect button).
#
# SUPABASE_PUBLISHABLE_KEY is the publishable key (sb_publishable_... or anon JWT).
# Safe to store in .env.local — does not bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY is optional — only needed for admin content editing.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Required table (run once in Supabase SQL editor):
#
#   create table experiment_submissions (
#     id          uuid        default gen_random_uuid() primary key,
#     experiment  text        not null,
#     email       text        not null,
#     name        text,
#     source      text        default 'landing-page',
#     notes       text,
#     metadata    jsonb,
#     created_at  timestamptz default now()
#   );

# Required table (run once in Supabase SQL editor):
#
#   create table experiment_content (
#     id              uuid        default gen_random_uuid() primary key,
#     experiment_id   text        not null,
#     content_type    text        not null,
#     content         text        not null,
#     updated_at      timestamptz default now(),
#     unique (experiment_id, content_type)
#   );

# ─── Edit mode ────────────────────────────────────────────────────────────────
# Secret used to unlock in-browser editing of experiment content.
# Visit /experiments/<slug>?edit=YOUR_SECRET to activate for 8 hours.
# Server-side only — never prefix with NEXT_PUBLIC_.
ADMIN_SECRET=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Restrict CORS for /api/landing-submission (default: *)
# LANDING_CORS_ORIGIN=https://your-landing-domain.com

# ─── Notion (Replit only) ─────────────────────────────────────────────────────
# The Replit connector handles Notion auth automatically in Replit environments.
# These are not needed on Vercel.
# NOTION_TOKEN=
