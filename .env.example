# Experiment Hub — environment variables
# Copy to .env.local for local dev (Next.js loads .env.local automatically).
# For Vercel: set these in Project Settings → Environment Variables.
#
# .env.local is also the canonical fallback for experiment prototypes:
# their scripts load their own local .env first (which wins when present),
# then fall back to this repo root .env.local — so shared keys like
# NOTION_TOKEN and SUPABASE_* only need to live here once. See e.g.
# experiments/etsy-notion-sync/prototype/.env.example.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Used for all experiment waitlist/form submissions.
# Find these in your Supabase project: Settings → API (or the Connect button).
#
# SUPABASE_PUBLISHABLE_KEY is the publishable key (sb_publishable_... or anon JWT).
# Safe to store in .env.local — does not bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY is optional — only needed for admin content editing.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Required table (run once in Supabase SQL editor):
#
#   create table experiment_submissions (
#     id          uuid        default gen_random_uuid() primary key,
#     experiment  text        not null,
#     email       text        not null,
#     name        text,
#     source      text        default 'landing-page',
#     notes       text,
#     metadata    jsonb,
#     created_at  timestamptz default now()
#   );

# Required table (run once in Supabase SQL editor):
#
#   create table experiment_content (
#     id              uuid        default gen_random_uuid() primary key,
#     experiment_id   text        not null,
#     content_type    text        not null,
#     content         text        not null,
#     updated_at      timestamptz default now(),
#     unique (experiment_id, content_type)
#   );

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Classic PAT with repo read scope — used to sync pull requests from GitHub.
# Generate at: https://github.com/settings/tokens
# GITHUB_TOKEN=

# ─── Etsy sync (etsy-notion-sync experiment) ─────────────────────────────────
# PAT with actions:write on this repo — lets the hub's "Sync now" button
# dispatch .github/workflows/etsy-notion-sync.yml. Server-side only.
# GITHUB_DISPATCH_TOKEN=
# Repo the workflow lives in (default: beckharrisdesign/experiment-hub).
# ETSY_SYNC_REPO=

# ─── Edit mode ────────────────────────────────────────────────────────────────
# Secret used to unlock in-browser editing of experiment content.
# Visit /experiments/<slug>?edit=YOUR_SECRET to activate for 8 hours.
# Server-side only — never prefix with NEXT_PUBLIC_.
ADMIN_SECRET=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Restrict CORS for /api/landing-submission (default: *)
# LANDING_CORS_ORIGIN=https://your-landing-domain.com

# ─── Notion ───────────────────────────────────────────────────────────────────
# NOTION_TOKEN: internal integration secret (notion.so/profile/integrations).
# Share the target databases with the integration. On Replit, the connector
# handles auth automatically and NOTION_TOKEN can be omitted.
# NOTION_TOKEN=
#
# When Notion auth is available (NOTION_TOKEN, or the Replit connector) AND
# NOTION_EXPERIMENTS_DATA_SOURCE_ID is set, experiments are read from the
# "BHD Labs Projects" Notion database instead of Supabase (Supabase/JSON
# remain as fallbacks). The data source id for BHD Labs Projects is
# 399b908d-7b37-80cb-beb5-000b54ca2967.
# NOTION_EXPERIMENTS_DATA_SOURCE_ID=
