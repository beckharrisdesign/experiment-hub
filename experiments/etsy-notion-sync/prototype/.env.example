# Env-file precedence: real environment > this prototype's .env > repo root
# .env.local. The repo root .env.local (documented in /.env.example) is the
# canonical home for keys shared across the hub and its experiments — e.g.
# NOTION_TOKEN, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY. Anything set there
# can be omitted here; values in this local .env always win when present.

# Etsy Open API v3 (Seller App credentials — scope: listings_r only)
# ETSY_API_KEY (keystring) and ETSY_SHARED_SECRET are filled by hand from the
# developer portal — since 2026-02-09 Etsy requires both, sent as
# "keystring:secret" in x-api-key. The other three are written by
# `python oauth_helper.py --write-env`. Access tokens last 1 hour —
# refresh before each scheduled run with `python oauth_helper.py --refresh --write-env`.
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_OAUTH_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_SHOP_ID=
# Comma-separated listing states to capture (active,inactive,sold_out,draft,expired)
ETSY_LISTING_STATES=active

# Notion internal integration (share the Inventory database with it).
# NOTION_TOKEN can live in the repo root .env.local instead (shared with the hub).
NOTION_TOKEN=
NOTION_INVENTORY_DB_ID=

# Notion property names in the Inventory database. Defaults match the real
# schema (2026-07-15): "Etsy price" and "Inventory level" are plain writable
# numbers; rows match on "Etsy Listing ID" first, then SKU as fallback.
NOTION_LISTING_ID_PROPERTY=Etsy Listing ID
NOTION_SKU_PROPERTY=SKU
NOTION_PRICE_PROPERTY=Etsy price
NOTION_QUANTITY_PROPERTY=Inventory level
NOTION_STATUS_PROPERTY=Status
# Optional override of the Etsy state -> Notion Status option mapping:
# ETSY_STATE_TO_STATUS_JSON={"active": "Active", "inactive": "Inactive"}
# Optional override of the extra Etsy fields mirrored into Notion (see
# DEFAULT_EXTRA_FIELDS in sync_notion.py — description, URL, views,
# favorites, tags, materials, currency, created/modified dates by default).
# Missing Notion properties are created automatically on the next run.
# NOTION_EXTRA_FIELDS_JSON=[{"parsed_key": "description", "property": "Description", "type": "rich_text"}]

# Safety
DRY_RUN=true
QUOTA_SAFETY_FLOOR=0.1
CAPTURE_DB_PATH=data/etsy_history.sqlite3

# Store backend: sqlite (local default) or supabase (server-side runs).
# Supabase mode also holds Etsy token custody (seed: oauth_helper.py --to-supabase).
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY can live in the repo root .env.local
# instead (shared with the hub).
STORE_BACKEND=sqlite
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
