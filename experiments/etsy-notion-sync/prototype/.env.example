# Etsy Open API v3 (Seller App credentials — scope: listings_r only)
# Only ETSY_API_KEY is filled by hand (the app keystring); the other three are
# written by `python oauth_helper.py --write-env`. Access tokens last 1 hour —
# refresh before each scheduled run with `python oauth_helper.py --refresh --write-env`.
ETSY_API_KEY=
ETSY_OAUTH_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_SHOP_ID=
# Comma-separated listing states to capture (active,inactive,sold_out,draft,expired)
ETSY_LISTING_STATES=active

# Notion internal integration (share the Inventory database with it)
NOTION_TOKEN=
NOTION_INVENTORY_DB_ID=

# Notion property names in the Inventory database
NOTION_SKU_PROPERTY=SKU
NOTION_PRICE_PROPERTY=Single price sum
NOTION_QUANTITY_PROPERTY=Inventory value
NOTION_STATUS_PROPERTY=Status
# Optional override of the Etsy state -> Notion Status option mapping:
# ETSY_STATE_TO_STATUS_JSON={"active": "Active", "inactive": "Inactive"}

# Safety
DRY_RUN=true
QUOTA_SAFETY_FLOOR=0.1
CAPTURE_DB_PATH=data/etsy_history.sqlite3
