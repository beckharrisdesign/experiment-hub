{
  "name": "experiment-hub",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "turbo run build --concurrency=2",
    "start": "next start",
    "test": "vitest run",
    "test:all": "turbo run test --concurrency=2",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "test:pbn": "bash scripts/test-pbn.sh",
    "pbn:ui": "bash scripts/pbn-ui.sh",
    "lint": "turbo run lint --concurrency=2",
    "setup:logging": "node scripts/setup-logging.js",
    "sitemap:capture": "node scripts/capture-site-map.js",
    "dev:landing": "cd experiments/simple-seed-organizer/prototype/validation-landing && pnpm install && pnpm dev",
    "dev:photo-filters-banner": "cd experiments/photo-filters-banner/prototype && npm install && npm run dev",
    "skills:sync": "node scripts/sync-skills.js"
  },
  "dependencies": {
    "@beckharrisdesign/mvds": "^0.2.0",
    "@notionhq/client": "^5.6.0",
    "@supabase/supabase-js": "^2.101.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "mermaid": "^11.13.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^28.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "turbo": "^2.5.4",
    "vitest": "^4.0.18"
  }
}
